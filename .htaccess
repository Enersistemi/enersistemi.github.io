# Configurazione Apache per l'hosting Serverplan.
# Questo file finisce nella cartella out/ insieme al sito esportato.
# Su Vercel/Cloudflare viene semplicemente ignorato.

# --- Indirizzo canonico: sempre https://www.enersistemi.com ---
RewriteEngine On
RewriteCond %{HTTPS} off [OR]
RewriteCond %{HTTP_HOST} !^www\. [NC]
RewriteCond %{HTTP_HOST} ^(?:www\.)?(.+)$ [NC]
RewriteRule ^ https://www.%1%{REQUEST_URI} [R=301,L]

# --- Pagina di errore ---
ErrorDocument 404 /404.html

# --- Codifica corretta ---
AddDefaultCharset UTF-8

# --- Cache: risorse versionate a lungo, HTML sempre fresco ---
<IfModule mod_expires.c>
  ExpiresActive On
  ExpiresByType text/html "access plus 0 seconds"
  ExpiresByType image/webp "access plus 30 days"
  ExpiresByType image/png "access plus 30 days"
  ExpiresByType image/svg+xml "access plus 30 days"
  ExpiresByType font/woff2 "access plus 1 year"
  ExpiresByType text/css "access plus 1 year"
  ExpiresByType application/javascript "access plus 1 year"
</IfModule>

# --- Compressione ---
<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE text/html text/css application/javascript application/json image/svg+xml
</IfModule>
